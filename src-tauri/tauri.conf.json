{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mykvm",
  "version": "0.1.0",
  "identifier": "com.xzhpl.mykvm",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MyKVM",
        "width": 1480,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "theme": "Dark",
        "fullscreen": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczRkM0ODZGQTQzNDQyQzQKUldURVFqU2tiMGo4YzVXTmFsNW92bi9HNkc4SU5rVGtwUFRqd1hrWGtHd3FQRlJmdVllUXhsdzQK",
      "endpoints": [
        "https://github.com/XxMinor/mykvm/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
